rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global authorization primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema Validation Helpers
    function isValidUser(user) {
      return user.username is string 
          && user.username.size() > 0 
          && user.username.size() <= 64;
    }

    function isValidChatMessage(msg) {
      return msg.sender is string 
          && msg.sender.size() > 0 
          && msg.sender.size() <= 64
          && msg.text is string 
          && msg.text.size() > 0 
          && msg.text.size() <= 2000
          && msg.userId == request.auth.uid;
    }

    // User accounts collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data))
                  || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) 
                      && (request.resource.data.likesCount == resource.data.likesCount + 1
                          || (!('likesCount' in resource.data) && request.resource.data.likesCount == 1)));
      allow delete: if false;
    }

    // Multiplayer Global Chat Room
    match /chat/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidChatMessage(request.resource.data);
      allow update, delete: if false;
    }
  }
}
